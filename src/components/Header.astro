---
import HamburgerButton from "./icons/HamburgerButton.astro";
const linkStyle =
  "focus:ring-4 focus:ring-cyan-500 focus:outline-none rounded-full hover:text-yellow-300 block md:inline p-2";
---

<header
  class="flex justify-center items-center py-5 w-full xl:w-280 mx-auto sticky top-0 bg-black z-50 rounded-b-3xl"
>
  <nav
    class="flex flex-row gap-x-2 md:gap-x-10 opacity-80 text-sm md:text-base"
  >
    <button id="menuBtn" class="md:hidden">
      <HamburgerButton />
    </button>
    <div
      id="menu"
      class="hidden md:flex flex-col md:flex-row align-center top-16 md:top-0 left-0 w-full md:w-auto p-4 md:p-0"
  >
    <a href="#top" class={`${linkStyle}`}>Inicio</a>
    <a href="#stackSection" class={`${linkStyle}`}>Stack</a>
    <a href="#experienceSection" class={`${linkStyle}`}>Experiencia</a>
    <a href="#projectsSection" class={`${linkStyle}`}>Proyectos</a>
    <a href="#aboutMeSection" class={`${linkStyle}`}>Sobre Mí</a>
    <a href="mailto:ariaslopezalberto1993@gmail.com" class={`${linkStyle}`}
      >Contactar</a
    >
    </div>
  </nav>
</header>
