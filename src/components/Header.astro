---
import HamburgerButton from "./icons/HamburgerButton.astro";
const linkClasses =
  "focus:ring-4 focus:ring-cyan-500 focus:outline-none rounded-full hover:text-yellow-300 block md:inline p-2 menuHover";
---

<header
  class="flex justify-start md:justify-center items-center py-5 w-full mx-auto sticky top-0 bg-black z-50 rounded-b-3xl"
>
  <nav
    class="flex flex-row gap-x-2 md:gap-x-10 opacity-80 text-sm md:text-base"
  >
    <button id="menuBtn" class="md:hidden menuHover ml-6">
      <HamburgerButton />
    </button>
    <div
      id="menu"
      class="hidden md:flex flex-col md:flex-row align-center top-16 md:top-0 left-0 w-full md:w-auto p-4 md:p-0"
    >
      <a href="#top" class={`${linkClasses} `}>Inicio</a>
      <a href="#stackSection" class={`${linkClasses}`}>Stack</a>
      <a href="#experienceSection" class={`${linkClasses}`}>Experiencia</a>
      <a href="#projectsSection" class={`${linkClasses}`}>Proyectos</a>
      <a href="#aboutMeSection" class={`${linkClasses}`}>Sobre Mí</a>
      <a href="mailto:ariaslopezalberto1993@gmail.com" class={`${linkClasses}`}
        >Contactar</a
      >
    </div>
  </nav>

  <script>
    window.addEventListener("DOMContentLoaded", () => {
      const menuBtn = document.getElementById("menuBtn");
      const menu = document.getElementById("menu");
      const menuHoverElements = document.querySelectorAll(".menuHover");
      if (menuBtn && menu) {
        menuHoverElements.forEach((element) => {
          element.addEventListener("click", () => {
            menu.classList.toggle("hidden");
            menuBtn.classList.toggle("hidden");
          });
          document.addEventListener("click", (e) => {
            if (!menuBtn.contains(e.target as Node)) {
              menu.classList.add("hidden");
              menuBtn.classList.remove("hidden");
            }
          });
        });
      }
    });
  </script>
</header>
