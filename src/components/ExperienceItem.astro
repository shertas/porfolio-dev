---
import RightArrowIcon from "../assets/RightArrow.svg";
interface Props {
  title: string;
  description: string;
  date: string;
  link?: string;
}
const { title, description, date, link } = Astro.props;
---

<div
  class="absolute w-3 h-3 bg-cyan-500 rounded-full mt-1.5 -inset-s-1.5 border border-"
>
</div>
<time
  class="text-xs md:text-sm font-normal leading-none text-body text-yellow-500"
  >{date}</time
>

<h3 class="text-sm md:text-lg font-semibold text-heading my-2 text-yellow-300">
  {title}
</h3>
<p
  class="text-xs md:text-base text-pretty text-justify font-normal text-body whitespace-pre-line mb-4"
>
  {description}
</p>
{
  link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center text-body bg-neutral-secondary-medium box-border border rounded-full hover:bg-neutral-tertiary-medium hover:text-heading focus:ring-4 focus:ring-neutral-tertiary shadow-xs font-medium leading-5 rounded-base text-xs md:text-sm px-4 py-1 md:py-2.5 focus:outline-none border-white/60 bg-cyan-800 hover:scale-110 hover:bg-cyan-500 transition"
    >
      Saber más...
      <RightArrowIcon class="size-2 md:size-4" />
    </a>
  )
}
